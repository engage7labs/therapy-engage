# CosmosDB Configuration
COSMOSDB_ENDPOINT=https://therapyengage-cosmosdb-dev.documents.azure.com:443/
COSMOSDB_DATABASE_NAME=therapyengage
COSMOSDB_CONTAINER_NAME=patient_videos

# Optional: CosmosDB Key (if not using managed identity)
# COSMOSDB_KEY=your_cosmosdb_primary_key_here

# OpenAI Configuration (for Whisper and Sentiment Analysis)
OPENAI_API_KEY=your_openai_api_key

# Azure OpenAI Configuration (alternative to standard OpenAI)
# AZURE_OPENAI_ENDPOINT=https://your-azure-openai.openai.azure.com
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Dragon Speech API Configuration (optional, preferred for transcription and sentiment)
# DRAGON_API_KEY=your_dragon_api_key
# DRAGON_API_ENDPOINT=https://api.dragon.speech.com

# Sentiment Analysis Configuration
# SENTIMENT_TIMEOUT=30000
# SENTIMENT_RETRY_ATTEMPTS=2

# Application Configuration
PORT=3001
NODE_ENV=development
