# .gitattributes – enforce LF line endings and mark binaries

# --- Default behaviour: auto‑normalize to LF ---

* text=auto eol=lf

# --- Explicit LF for common code / config files ---

\*.tf     text eol=lf
\*.ts     text eol=lf
\*.tsx    text eol=lf
\*.js     text eol=lf
\*.jsx    text eol=lf
\*.json   text eol=lf
\*.graphql text eol=lf
\*.yml    text eol=lf
\*.yaml   text eol=lf
\*.sh     text eol=lf
\*.md     text eol=lf

# --- Treat the following as binary (no EOL conversion) ---

\*.png  binary
\*.jpg  binary
\*.jpeg binary
\*.gif  binary
\*.svg  binary
\*.ico  binary
\*.zip  binary
\*.gz   binary
\*.bz2  binary
\*.tar  binary
\*.tgz  binary
\*.pdf  binary
\*.mp4  binary
\*.mp3  binary
\*.exe  binary
\*.dll  binary